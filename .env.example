# デジタライズ API（.env をコピーして値を入れ、Vercel の Environment Variables にも同じキーを登録）
SECRET_ID=
SECRET_PASSWORD=

# Vercel 本番で必須（32文字以上のランダム文字列推奨）
JWT_SECRET=

# ── 顧客キャッシュ・物件メタ（LibSQL / Turso）────────────────
# ローカル省略時: data/sync.db（ファイル）
# Turso 利用時:
#   1) ダッシュボードの Database URL（libsql://<db>.<region>.turso.io）を DATABASE_URL に設定
#   2) Turso CLI またはダッシュボードで「Token」を発行し TURSO_AUTH_TOKEN に設定（read/write）
#   3) 初回 API 起動時に migrate が走りテーブルが作成される
# DATABASE_URL が最優先。未設定かつ VERCEL のときのみメモリ DB にフォールバック。
DATABASE_URL=
# DATABASE_URL と同じ URL を入れる場合の別名（どちらか一方で可）
TURSO_DATABASE_URL=
# リモート libsql:// 接続時は必須（無いと接続エラー）
TURSO_AUTH_TOKEN=
# エイリアス（TURSO_AUTH_TOKEN と同じ値で可）
TURSO_API_TOKEN=
# ローカルでファイル DB の場所だけ変えたいとき
# REM_DATA_DIR=/absolute/path/to/data

# 招待メール送信（AWS SES SMTP も可）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# 例: https://your-app.vercel.app/login.html
APP_LOGIN_URL=
# 例: https://your-app.vercel.app
APP_URL=

# 素材ギャラリー S3（署名付きURL）。バケット名・リージョンは各物件詳細の「素材ギャラリー用 S3」で登録
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
AWS_S3_UPLOAD_EXPIRES=300
# 最大5GB（単発PUTの上限）
AWS_S3_MAX_FILE_SIZE=5368709120
