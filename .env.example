# デジタライズ API（.env をコピーして値を入れ、Vercel の Environment Variables にも同じキーを登録）
SECRET_ID=
SECRET_PASSWORD=

# Vercel 本番で必須（32文字以上のランダム文字列推奨）
JWT_SECRET=

# 顧客キャッシュ DB（省略時はリポジトリの data/sync.db。起動ディレクトリに依存しない）
# REM_DATA_DIR=/absolute/path/to/data  … 任意で DB 配置を上書き
# 本番（Vercel）では Turso 等の LibSQL を推奨: DATABASE_URL=libsql://....turso.io
DATABASE_URL=
# Turso の場合はこちらの名前でも可
TURSO_DATABASE_URL=
# Turso の場合に必須
TURSO_AUTH_TOKEN=
# Turso で UI によってはこの名前が表示されます
TURSO_API_TOKEN=
