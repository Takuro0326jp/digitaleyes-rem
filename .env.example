# デジタライズ API（.env をコピーして値を入れ、Vercel の Environment Variables にも同じキーを登録）
SECRET_ID=
SECRET_PASSWORD=

# Vercel 本番で必須（32文字以上のランダム文字列推奨）
JWT_SECRET=

# ── 顧客キャッシュ・物件メタ（LibSQL / Turso）────────────────
# 【ローカル（proxy / node）】既定は data/sync.db のみ使用。.env に DATABASE_URL があっても無視される。
#   本番 Turso をローカルから触りたいときだけ REM_USE_REMOTE_SYNC_DB=1 とし、下の DATABASE_URL + トークンを設定。
# 【Vercel】環境変数の DATABASE_URL + TURSO_AUTH_TOKEN を使用。未設定時はメモリ DB（非永続）。
REM_USE_REMOTE_SYNC_DB=
# Turso（本番は Vercel に設定。ローカルでリモートを使うときもここに書く）
#   1) Database URL（libsql://<db>.<region>.turso.io）
#   2) Turso の read/write トークンを TURSO_AUTH_TOKEN
DATABASE_URL=
# DATABASE_URL と同じ URL を入れる場合の別名（どちらか一方で可）
TURSO_DATABASE_URL=
# リモート libsql:// 接続時は必須（無いと接続エラー）
TURSO_AUTH_TOKEN=
# エイリアス（TURSO_AUTH_TOKEN と同じ値で可）
TURSO_API_TOKEN=
# ローカルでファイル DB の場所だけ変えたいとき
# REM_DATA_DIR=/absolute/path/to/data

# 招待メール送信（AWS SES SMTP も可）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# 例: https://your-app.vercel.app/login.html
APP_LOGIN_URL=
# 例: https://your-app.vercel.app
APP_URL=

# ローカル proxy-server.js の待受ポート（既定 3001。別アプリが 3001 を占有しているときは 3010 などに変更）
# PORT=3010

# 【復旧・ローカル専用】1 のときメール2FAを省略し、パスワードのみでJWT/セッションを返す。本番では原則未設定。
# REM_SKIP_2FA=1

# 素材ギャラリー S3（署名付きURL）。バケット名・リージョンは各物件詳細の「素材ギャラリー用 S3」で登録
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
AWS_S3_UPLOAD_EXPIRES=300
# 最大5GB（単発PUTの上限）
AWS_S3_MAX_FILE_SIZE=5368709120

# ── 初回マスター（デプロイ時のみ。パスワードはリポジトリに書かない）────────────────
# 1 のとき、起動時に 1 回だけマスター( role=1 )を作成または更新（SHA-256 ハッシュで保存）
# REM_BOOTSTRAP_MASTER=1
# REM_MASTER_EMAIL=
# REM_MASTER_PASSWORD=
# REM_MASTER_NAME=
# REM_MASTER_CLIENT=
# REM_MASTER_TENANT_ID=
